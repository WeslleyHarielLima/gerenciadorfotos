# ─── Ambiente ─────────────────────────────────────
# DEBUG é o flag autoritativo (B2): por omissão é FALSE (produção segura).
# Em desenvolvimento, ligue explicitamente (o dev.sh já exporta DEBUG=true).
DEBUG=false
# Hosts aceitos no header Host (B4). Em produção: seu-dominio.com.br,www.seu-dominio.com.br
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Banco de Dados ───────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_HOST_PORT=5433
DB_NAME=workflow_studio
DB_USER=workflow_user
# Em produção NÃO pode ser 'dev_password' (Q7 aborta o boot). Use senha forte ou o GSM.
DB_PASSWORD=dev_password
DB_VOLUME=workflow_postgres_data
GSM_SECRET_NAME=workflow-postgres-password

# ─── Google APIs ──────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CALENDAR_ID=seu-email@exemplo.com
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-root-folder-id

# ─── Service Account (única para Drive + Calendar) ─
# E-mail é identificador (pode versionar); a chave privada JSON fica no GSM —
# aqui só o NOME do segredo, nunca o JSON em si.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_SECRET=your-sa-key-secret-name
# Dev com Gmail pessoal: use OAuth2 (gera com: python scripts/authorize_drive.py)
GOOGLE_OAUTH_TOKEN_FILE=../docs/drive_token.json
# Calendar OAuth2 token (gera com: python scripts/authorize_calendar.py)
GOOGLE_OAUTH_CALENDAR_TOKEN_FILE=../docs/calendar_token.json
# Prod (B6): a service account é montada em runtime via docker-compose. Caminho HOST
# do JSON da SA (default no compose aponta para ./docs/...). Nunca versionar o JSON.
# GOOGLE_SA_HOST_PATH=./docs/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json   # caminho DENTRO do container

# ─── JWT ──────────────────────────────────────────
JWT_SECRET_NAME=workflow-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ─── Serviços / CORS ──────────────────────────────
DJANGO_PORT=8000
FRONTEND_URL=https://seu-dominio.exemplo.com
# Origens extras liberadas no CORS/CSRF em produção (CSV), além de FRONTEND_URL.
# CORS_EXTRA_ORIGINS=https://app.exemplo.com
# CSRF_TRUSTED_ORIGINS=https://app.exemplo.com

# ─── Limites de memória / upload (I5) ─────────────
# Tetos com defaults seguros embutidos no código; ajuste se necessário.
# MAX_UPLOAD_BYTES=104857600          # 100 MB por arquivo
# MAX_DOWNLOAD_BATCH=50               # itens por lote de download
# MAX_DOWNLOAD_TOTAL_BYTES=524288000  # 500 MB acumulados no zip

# ─── Django (nunca versionar o valor real) ────────
# Em produção NÃO pode ser o default inseguro (B3 aborta o boot). Gere com:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change-me-in-production

# ─── Cloudinary ───────────────────────────────────
# cloud_name fica em env; api_key/api_secret vêm do GSM em produção (Q6),
# com fallback para estas envs (nomes dos segredos abaixo).
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_API_KEY_SECRET_NAME=cloudinary-api-key
# CLOUDINARY_API_SECRET_SECRET_NAME=cloudinary-api-secret

# ─── Thresholds de gargalo (dashboard admin, em horas) ────
BOTTLENECK_UPLOADED_HOURS=48
BOTTLENECK_EDITING_HOURS=72
BOTTLENECK_REVIEW_HOURS=24
BOTTLENECK_APPROVED_HOURS=24
